{
  "manifest_version": 3,
  "name": "AIO - All In One Tools",
  "version": "1.0.3",
  "description": "All-in-one browser tools: Tab Manager, Screenshot Tool, Picture-in-Picture Video Player, Right-Click Enabler, ImageUS, and more.",
  "author": "Bishal Aryal",
  "homepage_url": "https://bishalaryal.com.np",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting",
    "downloads",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["editor.html", "editor.css", "editor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
